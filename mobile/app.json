{
    "expo": {
        "name": "CBR",
        "slug": "CBR",
        "version": "1.4.1-31",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "scheme": "cbr",
        "userInterfaceStyle": "automatic",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#ffffff"
            },
            "package": "org.hopehealthaction.cbrapp",
            "versionCode": 31,
            "blockedPermissions": [
                "android.permission.READ_EXTERNAL_STORAGE",
                "android.permission.WRITE_EXTERNAL_STORAGE"
            ]
        },
        "web": {
            "bundler": "metro",
            "output": "static",
            "favicon": "./assets/favicon.png"
        },
        "plugins": [
            "expo-router",
            "expo-image-picker",
            [
                "expo-build-properties",
                {
                    "android": {
                        "targetSdkVersion": 35
                    }
                }
            ],
            "expo-localization",
            "./plugins/withAndroidSigningConfig.ts",
            "./plugins/withDetoxTest.ts"
        ],
        "experiments": {
            "typedRoutes": true
        },
        "ios": {
            "bundleIdentifier": "org.hopehealthaction.cbrapp"
        }
    }
}
