{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "jsx": "react",
        "experimentalDecorators": true, // allow @nozbe/watermelondb/decorators
        "strict": true,
        "paths": {
            "@/*": [
                "./*"
            ]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".expo/types/**/*.ts",
        "expo-env.d.ts"
    ]
}
  